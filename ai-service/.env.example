# 基于大语言模型的智能新闻摘要与协同互动系统 - AI 服务配置示例
# 说明：本文件为配置示例，包含占位符。请根据实际情况复制为 .env 并填入真实值。
# 注意：.env 文件已被 .gitignore 忽略，不会被提交到版本库。

# 服务基础配置
PROJECT_NAME=基于大语言模型的智能新闻摘要与协同互动系统
SERVICE_NAME=ai-service
AI_API_PREFIX=/ai
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8001
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ========== 双AI架构配置（阶段 9.2+） ==========

# AI 1：摘要生成器配置
# 负责生成新闻摘要内容
SUMMARY_LLM_ENABLED=true
# 服务商（当前支持：deepseek, zhipu）
SUMMARY_LLM_PROVIDER=deepseek
# API Key（请替换为实际值）
# DeepSeek 获取地址: https://platform.deepseek.com/
# 智谱获取地址: https://open.bigmodel.cn/
SUMMARY_LLM_API_KEY=YOUR_API_KEY
# API 基础 URL
SUMMARY_LLM_BASE_URL=https://api.deepseek.com/v1
# 模型名称（DeepSeek: deepseek-chat; 智谱: glm-4-flash, glm-4）
SUMMARY_LLM_MODEL=deepseek-chat
# 超时时间（秒）
SUMMARY_LLM_TIMEOUT=45
# 温度参数（0.0-1.0，值越小生成越确定性）
SUMMARY_LLM_TEMPERATURE=0.3
# 最大返回 Token 数
SUMMARY_LLM_MAX_TOKENS=2048

# AI 2：证据评估器配置
# 负责为摘要中的每句话匹配原文证据并评估置信度
# 注意：开启此功能会增加约30-60秒的响应时间
EVIDENCE_LLM_ENABLED=true
# 服务商（当前支持：zhipu）
EVIDENCE_LLM_PROVIDER=zhipu
# API Key（请替换为实际值）
# 智谱获取地址: https://open.bigmodel.cn/
EVIDENCE_LLM_API_KEY=YOUR_API_KEY
# API 基础 URL（智谱官方地址）
EVIDENCE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# 模型名称（推荐使用 glm-4-flash 或 glm-4）
EVIDENCE_LLM_MODEL=glm-4-flash
# 超时时间（秒）
EVIDENCE_LLM_TIMEOUT=45
# 温度参数（建议设置较低值以保证评估一致性）
EVIDENCE_LLM_TEMPERATURE=0.1
# 最大返回 Token 数（证据评估需要较大的上下文窗口）
EVIDENCE_LLM_MAX_TOKENS=4096
