# 基于大语言模型的智能新闻摘要与协同互动系统 - AI 服务配置示例
# 说明：本文件为配置示例，包含占位符。请根据实际情况复制为 .env 并填入真实值。
# 注意：.env 文件已被 .gitignore 忽略，不会被提交到版本库。

# 服务基础配置
PROJECT_NAME=基于大语言模型的智能新闻摘要与协同互动系统
SERVICE_NAME=ai-service
AI_API_PREFIX=/ai
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8001
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# LLM 配置（阶段 9.1+）
# 启用/禁用 LLM 功能
# true: 调用智谱 GLM-4-Flash（2-5 秒延迟）
# false: 使用动态 mock（快速返回，<100ms）
LLM_ENABLED=true

# LLM 服务商（当前支持：zhipu）
LLM_PROVIDER=zhipu

# API Key（智谱 API Key，请替换为实际值）
# 获取地址: https://open.bigmodel.cn/
LLM_API_KEY=sk-12d2a148843c4e1280de2d391956a70e.bQVxknQGjX3GjdmY

# API 基础 URL（智谱官方地址）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 模型名称（智谱现有模型：glm-4-flash, glm-4, glm-3-turbo 等）
LLM_MODEL=glm-4-flash

# 超时时间（秒）
# 建议设置为 45-60 秒，支持网络延迟
LLM_TIMEOUT=45

# 温度参数（0.0-1.0，值越小生成越确定性）
LLM_TEMPERATURE=0.3

# 最大返回 Token 数
# 如果响应较慢，可以尝试改为 1200 或 1500
LLM_MAX_TOKENS=2048

# 思维链类型（disabled/enabled）
# 当前建议保持 disabled
LLM_THINKING_TYPE=disabled
